# This file contains environment variables for the CloudPi application.
# ==========================================================
# APPLICATION HOST & PROTOCOL CONFIGURATION
# ==========================================================
# Note: When creating or editing the cloudpi.secrets file, ensure that quotation marks are added around every value.
# HOST is used as a fallback or for internal references.
# For HTTP, if HOST is 'localhost' or empty, the script will try to use the public IP.
# If HOST is set to a specific domain/IP, that will be used for HTTP.
HOST=cloudpivk9.nichesoft.ai
# Set HTTPS to true to enable HTTPS.
# If true, you MUST provide SSL_CERT_PATH and SSL_KEY_PATH.
# If true and SUBDOMAIN is set, SUBDOMAIN will be the primary host value.
# If true and SUBDOMAIN is empty, the script will attempt to fetch the public IP.
HTTPS=true
# SUBDOMAIN is used if HTTPS=true. E.g., myapp.cloudpie.ai
# If HTTPS=false and SUBDOMAIN is set, it can also be used as the host_value.
SUBDOMAIN=cloudpivk9.nichesoft.ai

# ==========================================================
# SERVICE CONFIGURATION
# ==========================================================
# Number of workers for PiFlask and potentially other services.
WORKERS=4
# ==========================================================
# CLIENT SPECIFIC SETTINGS
# ==========================================================
# By default, these are placeholders. Update them with actual client information and for CLIENT_BILLING_COST_TYPE billed_cost is the default.
CLIENT_NAME=Nichesoft Technologies Inc
CLIENT_CODE=Nichesoft
CLIENT_DOMAIN=nichesoft.ai
CLIENT_EMAIL=venkat@nichesoft.ai
CLIENT_CONTACT_NAME=venkat
CLIENT_CONTACT_NUMBER=+19787266685
FISCAL_YEAR=JAN-DEC
CLIENT_BILLING_COST_TYPE=effective_cost 
# NODE_ENV = 'development'

# CLIENT_BILLING_COST_TYPE=billed_cost | effective_cost | list_cost
# CLIENT_BILLING_COST_TYPE= effective_cost 


# ==========================================================
# DATABASE CONFIGURATION
# ==========================================================
DB_USER=masteradmin
MYSQL_USER=masteradmin
MYSQL_DATABASE=pidb

# ==========================================================
# SSL CERTIFICATE PATHS (Required if HTTPS=true)
# ==========================================================
# Ensure these files are volume-mounted into the container at these paths (e.g., to /home/certs) and has proper permissions (write-permissions).
CERT_PATH=/home/certs/certificate.crt
KEY_PATH=/home/certs/private.key
CA_BUNDLE_PATH=/home/certs/ca_bundle.crt
MIGRATION_TIMEOUT_MS=900000
DATA_COLLECTION_INTERVAL_HOURS=1